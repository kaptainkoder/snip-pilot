{
  "name": "snip-pilot",
  "version": "0.2.1",
  "description": "A local-first macOS screenshot, snipping, annotation, and agent handoff desktop app.",
  "main": "src/main.js",
  "author": "Snip Pilot contributors",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac dmg --arm64"
  },
  "build": {
    "appId": "local.snippilot.app",
    "productName": "Snip Pilot",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "jimp": "^1.6.1"
  }
}
